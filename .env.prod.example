# === ResPawn Production Environment Variables ===
# Copy this to .env.prod and fill in real values. NEVER commit .env.prod.

# --- PostgreSQL ---
POSTGRES_DB=respawn
DB_USERNAME=respawn_user
DB_PASSWORD=<STRONG_PASSWORD_HERE>
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://postgres:5432/respawn
DOCKER_DB_URL=jdbc:postgresql://postgres:5432/respawn

# --- TLS / Certificates ---
RELATIVE_KEY_PATH=/app/self_signed_certs/respawnkey
KEYSTORE_LOCATION=/app/self_signed_certs/respawnkey
KEYSTORE_PASSWORD=<CERT_PASSWORD>
KEY_PASSWORD=<CERT_PASSWORD>
PFX_FILE_PATH=/app/self_signed_certs/respawn.com.pfx
PFX_PASSWORD=<CERT_PASSWORD>

# --- JWT ---
JWT__KEY=<LONG_RANDOM_STRING_MIN_32_CHARS>
JWT__ISSUER=JWTAuthenticationServer
JWT__AUDIENCE=JWTServiceBlazorClient
JWT__SUBJECT=JWTServiceAccessToken

# --- Confluent Cloud Kafka ---
CONFLUENT_API_KEY=<YOUR_CONFLUENT_API_KEY>
CONFLUENT_API_SECRET=<YOUR_CONFLUENT_API_SECRET>

# --- SMTP (Mailgun) ---
SMTP__USERNAME=<MAILGUN_SMTP_USERNAME>
SMTP__PASSWORD=<MAILGUN_SMTP_PASSWORD>
